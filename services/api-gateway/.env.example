# API Gateway environment variable reference.
# Copy to .env and fill in values for local development.
# Never commit .env to source control.

# Azure AI Foundry project endpoint
PROJECT_ENDPOINT=https://<your-foundry-account>.openai.azure.com/

# Azure region
AZURE_LOCATION=eastus

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aap

# Cosmos DB connection
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=aap
COSMOS_CONTAINER=incidents

# Key Vault URL for per-subscription SPN credential storage
KEY_VAULT_URL=https://kv-aap-prod.vault.azure.net/
