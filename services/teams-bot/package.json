{
  "name": "teams-bot",
  "version": "1.0.0",
  "description": "Azure Agentic Platform Teams bot service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "botbuilder": "^4.23.0",
    "@microsoft/teams-ai": "^1.5.0",
    "express": "^4.21.0",
    "@azure/identity": "^4.5.0",
    "adaptivecards": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
