# Azure Bot Service Registration
BOT_ID=                              # Azure AD app registration client ID
BOT_PASSWORD=                        # Azure AD app registration client secret (or empty for managed identity)
BOT_TENANT_ID=                       # Entra tenant ID (single-tenant)

# API Gateway Connection
API_GATEWAY_INTERNAL_URL=http://api-gateway.internal.svc   # Internal VNet URL of api-gateway
API_GATEWAY_CLIENT_ID=               # Client ID of api-gateway Entra app registration (for token scope)

# DEPRECATED: API_GATEWAY_PUBLIC_URL is no longer embedded in card action URLs
# after the Action.Execute migration (cards route through the bot, not direct HTTP).
# Kept for forward-compatibility if future card types need direct api-gateway URLs.
API_GATEWAY_PUBLIC_URL=              # Public URL of api-gateway (currently unused post-Action.Execute)

# Web UI
WEB_UI_PUBLIC_URL=https://aap.example.com   # Public URL for deep links in Adaptive Cards (Investigate + reminder cards)

# Teams Channel
TEAMS_CHANNEL_ID=                    # Default Teams channel ID for proactive card posting

# Escalation
ESCALATION_INTERVAL_MINUTES=15       # Minutes before unacted approval triggers reminder (default: 15)

# Server
PORT=3978                            # Express server port (Teams convention: 3978)

# Azure Identity (auto-resolved on Container Apps)
# AZURE_CLIENT_ID=                   # Set automatically by Container Apps managed identity
